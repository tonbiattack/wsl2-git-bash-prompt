# git-prompt スクリプトを読み込む（__git_ps1 関数を使えるようにする）
# /usr/lib/git-core/git-sh-prompt が存在しない場合は /etc/bash_completion.d/git-prompt を試みる
source /usr/lib/git-core/git-sh-prompt 2>/dev/null || source /etc/bash_completion.d/git-prompt 2>/dev/null

# 未コミットの変更があると * や + を表示する
GIT_PS1_SHOWDIRTYSTATE=1
# 未追跡ファイルがあると % を表示する
GIT_PS1_SHOWUNTRACKEDFILES=1

# PS1 はプロンプトの表示形式を定義する変数
#
# 色の仕組み：ANSI エスケープコード
#   端末は \e[ で始まる特殊な文字列（エスケープシーケンス）を受け取ると、
#   文字として表示せず「色を変えろ」などの命令として解釈する。
#
#   書式: \e[<コード>m
#     \e   = ESC 文字（エスケープ）
#     [    = 制御シーケンスの開始
#     <コード> = 色・スタイルを表す数値
#     m    = 制御シーケンスの終端
#
#   主な色コード:
#     32 = 緑    33 = 黄色    34 = 青
#     0  = リセット（以降の文字を通常色に戻す）
#
# PS1 内で色を使う際の \[ \] の役割：
#   bash はプロンプトの「表示上の幅」を計算してカーソル位置を管理する。
#   エスケープコードは画面上に表示されない（幅ゼロ）ため、
#   \[ ... \] で囲んで「この範囲は幅ゼロの文字だ」と bash に伝える。
#   これを省略するとカーソルがずれる。
#
# 各部分の説明:
#   \[\e[32m\]   → 緑色 開始
#   \u@\h        → ユーザー名@ホスト名
#   \[\e[0m\]    → 色リセット
#   \[\e[33m\]   → 黄色 開始
#   \w           → カレントディレクトリ
#   \[\e[0m\]    → 色リセット
#   $(__git_ps1 " \[\e[34m\](%s)\[\e[0m\]")
#                → ブランチ名を (main) の形式で青色表示（git リポジトリ外では非表示）
#   \n\$         → 改行して $ を表示
export PS1='\[\e[32m\]\u@\h\[\e[0m\] \[\e[33m\]\w\[\e[0m\]$(__git_ps1 " \[\e[34m\](%s)\[\e[0m\]")\n\$ '
